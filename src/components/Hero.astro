<script>
	const profiles = [
		{
			title: 'WEB DEVELOPER',
			subtitle: { es: 'Creando experiencias digitales', en: 'Creating digital experiences' },
			tagsId: 'tags-dev'
		},
		{
			title: 'SENIOR IT SUPPORT',
			subtitle: { es: 'Experiencia en Infraestructura y Sistemas', en: 'Infrastructure and Systems Expertise' },
			tagsId: 'tags-it'
		}
	];

	let currentIndex = 0;
	const titleElement = document.getElementById('title-text') as HTMLElement;
	const subtitleContainer = document.getElementById('subtitle-text') as HTMLElement;
	const subtitleText = subtitleContainer.querySelector('.typed-text') as HTMLElement;
	const profileButtons = document.querySelectorAll('.profile-btn');

	function resizeTitle() {
		const maxFontSize = 128;
		const minFontSize = 16;
		const availableWidth = Math.min(window.innerWidth - 64, 1400 - 64);

		titleElement.style.fontSize = maxFontSize + 'px';

		let fontSize = maxFontSize;
		while (titleElement.scrollWidth > availableWidth && fontSize > minFontSize) {
			fontSize -= 2;
			titleElement.style.fontSize = fontSize + 'px';
		}
	}

	resizeTitle();
	window.addEventListener('resize', resizeTitle);

	function updateContent(profileIndex: number) {
		const currentLang = document.documentElement.getAttribute('data-lang') || 'es';
		const profile = profiles[currentIndex];
		const nextProfile = profiles[profileIndex];

		profileButtons.forEach(btn => btn.classList.remove('active'));
		profileButtons[profileIndex].classList.add('active');

		titleElement.style.opacity = '0';
		subtitleContainer.style.opacity = '0';
		document.getElementById(profile.tagsId)?.classList.remove('active');

		setTimeout(() => {
			titleElement.textContent = nextProfile.title;
			subtitleText.setAttribute('data-lang-es', nextProfile.subtitle.es);
			subtitleText.setAttribute('data-lang-en', nextProfile.subtitle.en);

			document.getElementById(nextProfile.tagsId)?.classList.add('active');

			resizeTitle();

			titleElement.style.opacity = '1';
			subtitleContainer.style.opacity = '1';

			currentIndex = profileIndex;
		}, 300);
	}

	profileButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const profileIndex = parseInt(button.getAttribute('data-profile') || '0');
			if (profileIndex !== currentIndex) {
				updateContent(profileIndex);
			}
		});
	});
</script>
