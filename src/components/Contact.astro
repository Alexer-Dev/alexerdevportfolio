<script>
	let currentTerminalProfile = 'dev';
	const terminalDev = document.getElementById('terminal-dev');
	const terminalIT = document.getElementById('terminal-it');

	function switchTerminal() {
		if (currentTerminalProfile === 'dev') {
			terminalDev.classList.remove('active');
			terminalIT.classList.add('active');
			currentTerminalProfile = 'it';
		} else {
			terminalIT.classList.remove('active');
			terminalDev.classList.add('active');
			currentTerminalProfile = 'dev';
		}
	}

	setInterval(switchTerminal, 6000);

	function updateTranslations() {
		const currentLang = document.documentElement.getAttribute('data-lang') || 'es';
		const elements = document.querySelectorAll('[data-lang-es][data-lang-en]');

		elements.forEach((el) => {
			const key = `data-lang-${currentLang}`;
			const text = el.getAttribute(key);
			if (text) {
				if (el.classList.contains('title-text')) {
					el.textContent = text.split('. ')[1] || text;
				} else if (el.classList.contains('contact-description')) {
					el.textContent = text;
				} else if (el.tagName === 'P' && el.classList.contains('footer')) {
					el.textContent = text;
				} else {
					el.textContent = text;
				}
			}
		});
	}

	updateTranslations();

	const observer = new MutationObserver(() => {
		updateTranslations();
	});

	observer.observe(document.documentElement, {
		attributes: true,
		attributeFilter: ['data-lang']
	});
</script>
